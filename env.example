# Copy this to .env or paste into Railway / Render Variables tab
# Do NOT commit real values to GitHub

# From @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your numeric Telegram user ID (get it from @userinfobot)
# Comma-separate multiple IDs: 123456789,987654321
ALLOWED_USER_IDS=your_numeric_id_here

# How often (in hours) the bot auto-pushes signals to you (default: 6)
AUTO_SCAN_HOURS=6

# How many top markets to show per scan (default: 10)
TOP_RESULTS=10
